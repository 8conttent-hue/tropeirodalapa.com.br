---
// Hero-I: Left Minimal Dark - Design sofisticado e direto
interface Props {
  title: string;
  subtitle: string;
  btnText: string;
  btnLink: string;
  bgImage: string;
}
const { title, subtitle, btnText, btnLink, bgImage } = Astro.props;
---
<section class="bg-dark text-white min-h-[80vh] flex items-center relative overflow-hidden">
  <!-- Subtle background graphic/image -->
  <div class="absolute right-[-10%] top-0 bottom-0 w-1/2 opacity-20 grayscale brightness-125 z-0">
    <img src={bgImage} class="w-full h-full object-cover" alt="Background detail" />
    <div class="absolute inset-y-0 left-0 w-64 bg-gradient-to-r from-dark to-transparent"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 relative z-10 w-full py-24">
    <div class="max-w-2xl">
      <div class="mb-12 h-[2px] w-24 bg-primary"></div>
      <h1 class="text-5xl md:text-8xl font-black mb-10 tracking-tight leading-none italic uppercase">
        {title}<span class="text-primary">.</span>
      </h1>
      <p class="text-xl md:text-2xl text-white/50 leading-relaxed max-w-xl mb-12 font-medium">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-6">
        <a 
          href={btnLink} 
          class="px-12 py-5 bg-white text-dark font-black rounded-lg hover:bg-primary hover:text-white transition-all text-xs uppercase tracking-widest shadow-2xl"
        >
          {btnText}
        </a>
        <a 
          href="#contato" 
          class="px-12 py-5 border border-white/10 text-white font-bold rounded-lg hover:border-white transition-colors text-xs uppercase tracking-widest"
        >
          Falar Conosco
        </a>
      </div>
    </div>
  </div>

  <!-- Abstract floating square -->
  <div class="absolute bottom-10 right-10 w-32 h-32 border-4 border-white/5 rotate-12 -z-10"></div>
</section>